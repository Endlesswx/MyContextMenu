<Window x:Class="ContextMenuManager.SoftwareMappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理关联软件映射"
        Height="600" Width="800" MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="#F5F6F8"
        FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" FontSize="13">
    <DockPanel>
        <!-- 顶部说明 -->
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1" Padding="20,16">
            <StackPanel>
                <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="#111827">
                    关联软件映射规则
                </TextBlock>
                <TextBlock Margin="0,8,0,0" Foreground="#6B7280" TextWrapping="Wrap" LineHeight="20">
                    程序会在菜单项的名称、命令、DLL路径等信息中搜索关键字（不区分大小写），匹配成功后在「关联软件」列显示对应的软件名称。
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 底部按钮 -->
        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnSave" Style="{StaticResource PrimaryBtn}" Content="保存" Click="BtnSave_Click"/>
                <Button x:Name="BtnCancel" Style="{StaticResource Btn}" Content="取消" Margin="0" Click="BtnCancel_Click"/>
            </StackPanel>
        </Border>

        <!-- 主区域 -->
        <DockPanel Margin="20,16,20,16">
            <!-- 工具栏 -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                <Button x:Name="BtnAdd" Style="{StaticResource PrimaryBtn}" Content="＋ 新增映射" Click="BtnAdd_Click"/>
                <Button x:Name="BtnEdit" Style="{StaticResource Btn}" Content="编辑" Click="BtnEdit_Click"/>
                <Button x:Name="BtnDelete" Style="{StaticResource Btn}" Content="删除" Click="BtnDelete_Click"/>
                <Button x:Name="BtnReload" Style="{StaticResource Btn}" Content="重新加载" Margin="0" Click="BtnReload_Click"
                        ToolTip="从配置文件重新加载（丢弃未保存的更改）"/>
            </StackPanel>

            <!-- 列表 -->
            <Border Background="White" BorderBrush="#E5E7EB"
                    BorderThickness="1" CornerRadius="8">
                <Grid>
                    <ListView x:Name="MappingList" BorderThickness="0" AlternationCount="2"
                              SelectionMode="Single" MouseDoubleClick="MappingList_MouseDoubleClick">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="MinHeight" Value="38"/>
                                <Setter Property="Padding" Value="6,3"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F9FAFB"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EFF6FF"/>
                                        <Setter Property="BorderBrush" Value="#BFDBFE"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F9FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="关键字" Width="300">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Key}" VerticalAlignment="Center"
                                                       FontFamily="Consolas, Courier New" Foreground="#374151"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="软件名称" Width="400">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Value}" VerticalAlignment="Center" 
                                                       Foreground="#111827" FontWeight="Medium"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <TextBlock x:Name="EmptyHint" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#9CA3AF" FontSize="14" Text="暂无映射规则"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>
        </DockPanel>
    </DockPanel>
</Window>
