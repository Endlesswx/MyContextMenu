<Window x:Class="ContextMenuManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="右键菜单管家 — Windows 右键菜单管理工具"
        Height="720" Width="1380" MinHeight="560" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8"
        FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" FontSize="13">
    <DockPanel>

        <!-- ══════════ 顶栏 ══════════ -->
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="{StaticResource BorderGray}"
                BorderThickness="0,0,0,1" Padding="18,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="右键菜单管家" FontSize="19" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="AdminBadge" Margin="14,3,0,0" FontSize="12" VerticalAlignment="Center"
                               Cursor="Hand" MouseLeftButtonUp="AdminBadge_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnAdd" Style="{StaticResource PrimaryBtn}" Content="＋ 新增菜单项" Click="BtnAdd_Click"/>
                    <Button x:Name="BtnManageMappings" Style="{StaticResource Btn}" Content="管理关联软件" Click="BtnManageMappings_Click"
                            ToolTip="管理关键字与软件名称的映射规则"/>
                    <Button x:Name="BtnRefresh" Style="{StaticResource Btn}" Content="刷新" Click="BtnRefresh_Click"/>
                    <Button x:Name="BtnWin11" Style="{StaticResource Btn}" Click="BtnWin11_Click"
                            Visibility="Collapsed"
                            ToolTip="在 Windows 11 精简菜单与经典完整菜单之间切换（仅影响当前用户）"/>
                    <Button x:Name="BtnRestartExplorer" Style="{StaticResource Btn}" Content="重启资源管理器"
                            Margin="0" Click="BtnRestartExplorer_Click"
                            ToolTip="部分修改需要重启资源管理器（explorer.exe）后才会生效"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════════ 状态栏 ══════════ -->
        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="{StaticResource BorderGray}"
                BorderThickness="0,1,0,0" Padding="18,7">
            <DockPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <TextBlock x:Name="CountText" Foreground="#666666"/>
                    <TextBlock Text="　" />
                    <TextBlock Foreground="{StaticResource AccentBrush}" Cursor="Hand"
                               MouseLeftButtonUp="OpenBackupDir_Click" Text="打开备份文件夹"
                               ToolTip="删除的项目会先备份到此文件夹（.reg 文件双击可还原）"/>
                </StackPanel>
                <TextBlock x:Name="StatusText" Text="就绪" Foreground="#444444" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- ══════════ 侧栏分类 ══════════ -->
        <Border DockPanel.Dock="Left" Width="212" Background="#FBFBFC"
                BorderBrush="{StaticResource BorderGray}" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="菜单分类" Foreground="#999999" FontSize="12"
                           Margin="16,14,0,6"/>
                <ListBox x:Name="CategoryList" BorderThickness="0" Background="Transparent"
                         ItemContainerStyle="{StaticResource CatItemStyle}"
                         SelectionChanged="CategoryList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding CountText}"
                                           Foreground="#999999" FontSize="12" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ══════════ 主区域 ══════════ -->
        <Grid Margin="18,14,18,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题与说明 -->
            <StackPanel Grid.Row="0">
                <TextBlock x:Name="CatTitle" FontSize="16" FontWeight="SemiBold" Foreground="#222222"/>
                <TextBlock x:Name="CatDesc" Foreground="#666666" FontSize="12" TextWrapping="Wrap" Margin="0,3,0,0"/>
                <TextBlock x:Name="Win11Tip" Foreground="#8A6D1F" FontSize="12" TextWrapping="Wrap"
                           Margin="0,3,0,0" Visibility="Collapsed"
                           Text="提示：Windows 11 默认使用精简右键菜单，此处管理的多数项目位于「显示更多选项」之中；点击右上角「切换 Win11 经典菜单」可换回完整菜单。"/>
            </StackPanel>

            <!-- 搜索 / 扩展名查询 -->
            <DockPanel Grid.Row="1" Margin="0,10,0,10">
                <StackPanel x:Name="ExtPanel" DockPanel.Dock="Left" Orientation="Horizontal" Visibility="Collapsed">
                    <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="10,6">
                        <Grid Width="160">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="📄" FontSize="14" 
                                       Margin="0,0,8,0" VerticalAlignment="Center" Opacity="0.7"/>
                            <TextBox x:Name="ExtBox" Grid.Column="1" BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center" FontSize="13"
                                     KeyDown="ExtBox_KeyDown" ToolTip="输入文件后缀名，例如 .txt 或 txt"/>
                        </Grid>
                    </Border>
                    <Button x:Name="BtnExtQuery" Style="{StaticResource Btn}" Content="查询" Margin="10,0,0,0"
                            Click="BtnExtQuery_Click"/>
                </StackPanel>
                <Grid Width="340" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="12,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍" FontSize="16" 
                                       Margin="0,0,10,0" VerticalAlignment="Center" Opacity="0.7"/>
                            <TextBox x:Name="SearchBox" Grid.Column="1" BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center" FontSize="13"
                                     TextChanged="SearchBox_TextChanged"/>
                            <TextBlock x:Name="SearchHint" Grid.Column="1" Text="搜索名称 / 命令 / 路径…" 
                                       Foreground="#9CA3AF" VerticalAlignment="Center" IsHitTestVisible="False" Margin="1,0,0,0"/>
                        </Grid>
                    </Border>
                </Grid>
                <Border/>
            </DockPanel>

            <!-- 列表 -->
            <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB"
                    BorderThickness="1" CornerRadius="8">
                <Grid>
                    <ListView x:Name="ItemList" BorderThickness="0" AlternationCount="2"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              SelectionMode="Single"
                              GridViewColumnHeader.Click="GridHeader_Click">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="MinHeight" Value="40"/>
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F9FAFB"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EFF6FF"/>
                                        <Setter Property="BorderBrush" Value="#BFDBFE"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F9FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="屏蔽 / 恢复" Click="CtxToggle_Click"/>
                                <MenuItem Header="删除（先备份）" Click="CtxDelete_Click"/>
                                <Separator/>
                                <MenuItem Header="定位（注册表 / 文件）" Click="CtxLocate_Click"/>
                                <MenuItem Header="复制位置路径" Click="CtxCopy_Click"/>
                                <Separator/>
                                <MenuItem x:Name="CtxSetSoftware" Header="设置关联软件..." Click="CtxSetSoftware_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="🔗" FontSize="14"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem x:Name="CtxClearSoftware" Header="清除关联软件" Click="CtxClearSoftware_Click"/>
                                <MenuItem x:Name="CtxAddMapping" Header="添加为新映射规则..." Click="CtxAddMapping_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="+" FontSize="14" FontWeight="Bold"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="状态" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#10B981"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                    <Setter Property="Fill" Value="#EF4444"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Margin="7,0,0,0" Text="{Binding StatusText}" VerticalAlignment="Center" FontWeight="Medium"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="名称" Width="240">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" ToolTip="{Binding FullLocation}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="类型" Width="86">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TypeLabel}" Foreground="#666666" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="位置" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SourceLabel}" Foreground="#666666"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                       ToolTip="{Binding FullLocation}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="分类" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding CategoryName}" Foreground="#888888"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                       ToolTip="{Binding CategoryName}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="关联软件" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding AssociatedSoftware}" Foreground="#3B82F6" FontWeight="Medium"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                       ToolTip="{Binding AssociatedSoftware}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="命令 / 详情" Width="260">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Details}" Foreground="#888888"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                       ToolTip="{Binding Details}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="操作" Width="196">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource RowBtn}" Content="{Binding ToggleText}"
                                                        Width="52" Click="RowToggle_Click"/>
                                                <Button Style="{StaticResource DangerBtn}" Content="删除" Click="RowDelete_Click"
                                                        Visibility="{Binding CanDelete, Converter={StaticResource BoolToVisible}}"/>
                                                <Button Style="{StaticResource RowBtn}" Content="定位" Margin="0"
                                                        Click="RowLocate_Click"
                                                        ToolTip="在注册表编辑器 / 资源管理器中定位此项"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <TextBlock x:Name="EmptyHint" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#999999" FontSize="13" TextAlignment="Center"
                               Visibility="Collapsed" Text="此分类下暂无项目"/>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
