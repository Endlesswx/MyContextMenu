<Window x:Class="ContextMenuManager.AddItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增菜单项" Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F6F8"
        FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif" FontSize="13">
    <StackPanel Margin="20,16,20,16">

        <!-- 类型选择 -->
        <Border Background="White" BorderBrush="{StaticResource BorderGray}" BorderThickness="1"
                CornerRadius="4" Padding="14,10" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="要新增：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <RadioButton x:Name="ModeVerb" Content="普通右键菜单项" IsChecked="True"
                             VerticalAlignment="Center" Margin="0,0,16,0" Checked="Mode_Changed"/>
                <RadioButton x:Name="ModeNew" Content="「新建」菜单项"
                             VerticalAlignment="Center" Margin="0,0,16,0" Checked="Mode_Changed"/>
                <RadioButton x:Name="ModeSendTo" Content="「发送到」项"
                             VerticalAlignment="Center" Checked="Mode_Changed"/>
            </StackPanel>
        </Border>

        <!-- ═══ 普通菜单项 ═══ -->
        <Border x:Name="PanelVerb" Background="White" BorderBrush="{StaticResource BorderGray}"
                BorderThickness="1" CornerRadius="4" Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="86"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="显示位置" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,10">
                    <ComboBox x:Name="TargetCombo" Width="200" SelectedIndex="1"
                              VerticalContentAlignment="Center" SelectionChanged="TargetCombo_SelectionChanged">
                        <ComboBoxItem Content="桌面空白处右键"/>
                        <ComboBoxItem Content="所有文件右键"/>
                        <ComboBoxItem Content="文件夹右键"/>
                        <ComboBoxItem Content="驱动器右键"/>
                        <ComboBoxItem Content="指定后缀名的文件右键"/>
                    </ComboBox>
                    <TextBox x:Name="VerbExtBox" Width="110" Margin="10,0,0,0" Padding="4,3"
                             Visibility="Collapsed" ToolTip="例如 .txt"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="菜单名称 *" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox x:Name="VerbNameBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                         Padding="4,3" Margin="0,0,0,10" TextChanged="VerbInput_Changed"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="程序 *" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox x:Name="VerbExeBox" Grid.Row="2" Grid.Column="1" Padding="4,3" Margin="0,0,8,10"
                         TextChanged="VerbInput_Changed"/>
                <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource Btn}" Content="浏览…"
                        Margin="0,0,0,10" Click="BrowseExe_Click"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="完整命令" VerticalAlignment="Center" Margin="0,0,0,4"/>
                <TextBox x:Name="VerbCmdBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                         Padding="4,3" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" FontSize="11" Foreground="#888888"
                           Margin="0,0,0,10" TextWrapping="Wrap"
                           Text="%1 = 被右键的文件/文件夹路径，%V = 当前目录路径。可手动修改。"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="图标" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox x:Name="VerbIconBox" Grid.Row="5" Grid.Column="1" Padding="4,3" Margin="0,0,8,10"
                         ToolTip="留空则使用程序自身图标"/>
                <Button Grid.Row="5" Grid.Column="2" Style="{StaticResource Btn}" Content="浏览…"
                        Margin="0,0,0,10" Click="BrowseIcon_Click"/>

                <StackPanel Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                    <CheckBox x:Name="VerbExtended" Content="仅按住 Shift 时显示" Margin="0,0,18,0"
                              ToolTip="Extended 菜单项：需要 Shift+右键 才会出现，避免菜单臃肿"/>
                    <CheckBox x:Name="VerbTop" Content="显示在菜单顶部"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ 「新建」菜单项 ═══ -->
        <Border x:Name="PanelNew" Background="White" BorderBrush="{StaticResource BorderGray}"
                BorderThickness="1" CornerRadius="4" Padding="14,12" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="86"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="后缀名 *" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox x:Name="NewExtBox" Grid.Row="0" Grid.Column="1" Padding="4,3" Margin="0,0,0,10"
                         ToolTip="例如 .md 或 md"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="类型名称" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox x:Name="NewTypeBox" Grid.Row="1" Grid.Column="1" Padding="4,3" Margin="0,0,0,10"
                         ToolTip="在「新建」菜单中显示的名称，例如「Markdown 文档」；留空则使用系统默认"/>
                <TextBlock Grid.Row="2" Grid.Column="1" FontSize="11" Foreground="#888888" TextWrapping="Wrap"
                           Text="将以「空白文件」方式注册（NullFile）：右键 → 新建 → 该类型，即可创建一个空文件。"/>
            </Grid>
        </Border>

        <!-- ═══ 「发送到」项 ═══ -->
        <Border x:Name="PanelSendTo" Background="White" BorderBrush="{StaticResource BorderGray}"
                BorderThickness="1" CornerRadius="4" Padding="14,12" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="86"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="显示名称 *" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox x:Name="SendToNameBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                         Padding="4,3" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="目标 *" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox x:Name="SendToTargetBox" Grid.Row="1" Grid.Column="1" Padding="4,3" Margin="0,0,8,10"/>
                <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource Btn}" Content="选择文件…"
                        Margin="0,0,8,10" Click="BrowseSendToFile_Click"/>
                <Button Grid.Row="1" Grid.Column="3" Style="{StaticResource Btn}" Content="选择文件夹…"
                        Margin="0,0,0,10" Click="BrowseSendToFolder_Click"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" FontSize="11" Foreground="#888888"
                           TextWrapping="Wrap"
                           Text="目标为程序：发送 = 用该程序打开所选文件；目标为文件夹：发送 = 复制文件到该文件夹。"/>
            </Grid>
        </Border>

        <!-- 按钮 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Style="{StaticResource PrimaryBtn}" Content="确定添加" MinWidth="92" Click="Ok_Click"/>
            <Button Style="{StaticResource Btn}" Content="取消" MinWidth="76" Margin="8,0,0,0" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
